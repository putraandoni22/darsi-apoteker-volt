{
  "name": "darsi-apoteker-volt",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo DARSI Apoteker RSI — chatbot AI + dashboard apoteker",
  "scripts": {
    "dev": "bash ./run-darsi.sh",
    "dev:chatbot": "npm run dev --prefix darsi_ph_chatbot",
    "dev:dashboard": "npm run dev --prefix darsi_ph_dashboard",
    "install:all": "npm install --prefix darsi_ph_chatbot && npm install --prefix darsi_ph_dashboard",
    "build:chatbot": "npm run build --prefix darsi_ph_chatbot",
    "build:dashboard": "npm run build --prefix darsi_ph_dashboard",
    "seed:master-obat": "node ./darsi_ph_dashboard/scripts/seed-master-obat.mjs",
    "seed:master-obat:dry": "node ./darsi_ph_dashboard/scripts/seed-master-obat.mjs --dry-run"
  }
}
